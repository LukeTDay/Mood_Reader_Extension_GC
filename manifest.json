{
  "manifest_version": 3,
  "name": "Moodify",
  "version": "1.0",
  "description": "Detects page mood and plays a matching Spotify playlist",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "identity"
  ],

  "host_permissions": [
    "https://api.spotify.com/*"
  ],

  "optional_host_permissions": [
    "https://api.anthropic.com/*",
    "https://api.openai.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/inactive.png"
  }
}